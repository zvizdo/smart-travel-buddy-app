# deploy/.env.example — committed template. Copy to deploy/.env and fill in real values.
# For CI/CD (GitHub Actions), set each variable as a repository secret instead.

PROJECT_ID=your-gcp-project-id
REGION=europe-west1
AR_REPO=stb-images

FRONTEND_SERVICE=smart-travel-buddy
BACKEND_SERVICE=smart-travel-buddy-backend
MCPSERVER_SERVICE=smart-travel-buddy-mcpserver

GCS_CHAT_HISTORY_BUCKET=staging.your-gcp-project-id.appspot.com

# Google Maps — server-side key (no referrer restriction, used by backend + MCP server)
GOOGLE_MAPS_API_KEY_SERVER=AIzaSy...
# Google Maps — client-side key (restrict by HTTP referrer in Cloud Console)
GOOGLE_MAPS_API_KEY_CLIENT=AIzaSy...

# HMAC secret for MCP API key verification (backend + MCP server)
API_KEY_HMAC_SECRET=...

# Firebase — public config baked into the JS bundle
# AUTH_DOMAIN and PROJECT_ID are automatically derived from PROJECT_ID if omitted.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-gcp-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-gcp-project-id
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional: Firebase Analytics (GA4) measurement ID for the web app. If blank,
# the frontend analytics stack is a no-op (no SDK init, no events). Get this
# from Firebase console > Project settings > General > Your apps > Web > SDK
# setup and configuration > Config (measurementId field, starts with "G-").
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: GA4 Measurement Protocol credentials for MCP server tool-call
# tracking. If either is blank, MCP AnalyticsService is a full no-op (no
# outbound HTTP, no warnings). Get both from Firebase console > Data streams
# > your web stream > Measurement Protocol API secrets.
GA_MEASUREMENT_ID=
GA_API_SECRET=

# Optional: set after first deploy once the Cloud Run URL is known
MCP_SERVER_URL=
