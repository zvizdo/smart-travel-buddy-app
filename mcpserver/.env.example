GOOGLE_CLOUD_PROJECT=
GOOGLE_MAPS_API_KEY=
API_KEY_HMAC_SECRET=

# URL of the deployed MCP server (Cloud Run)
MCP_SERVER_URL=https://your-cloudrun-url

# Optional: GA4 Measurement Protocol credentials for tracking mcp_tool_called
# events. If either is blank, AnalyticsService is a full no-op (no outbound
# HTTP, no warnings). Get both from Firebase console > Data streams > your
# web stream > Measurement Protocol API secrets.
GA_MEASUREMENT_ID=
GA_API_SECRET=
